# Donify Notification System Environment Configuration
# Copy this file to .env and fill in your actual credentials

# ============================================================================
# EMAILJS CONFIGURATION (For Email Notifications - EASY & FREE)
# ============================================================================
# RECOMMENDED: EmailJS is FREE and easiest to set up
# Sign up for free at: https://www.emailjs.com
# 
# Setup Steps:
# 1. Go to emailjs.com → Sign up (free)
# 2. Dashboard → Email Services → Add New Service
#    - Choose Gmail or any email provider
#    - Authorize it
# 3. Dashboard → Email Templates → Create Template
#    - Use variables like {{to_email}}, {{subject}}, {{message}}
# 4. Get your IDs:
#    - Service ID: Dashboard → Email Services → Copy Service ID
#    - Template ID: Dashboard → Templates → Copy Template ID  
#    - Public Key: Dashboard → Account → API Keys → Copy Public Key

# Your EmailJS Service ID
# Example: service_abc123xyz
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxxxxxxxxxx

# Your EmailJS Template ID
# Example: template_abc123xyz
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxxxxxxxxxx

# Your EmailJS Public Key (NOT private key!)
# Example: aBcDeFgHiJkLmNoPqRsT
REACT_APP_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# TWILIO CONFIGURATION (For SMS & WhatsApp Notifications - OPTIONAL, PAID)
# ============================================================================
# Sign up at: https://www.twilio.com
# Get credentials from: https://www.twilio.com/console

# Your Twilio Account SID
# Find at: Console → Account SID
REACT_APP_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token
# Find at: Console → Auth Token
REACT_APP_TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio Phone Number for SMS
# Format: +1 (country code)(area code)(number)
# Example: +15551234567
REACT_APP_TWILIO_PHONE_NUMBER=+15550150

# Your Twilio WhatsApp Number
# Usually the same as SMS number or WhatsApp sandbox number
# Example: +14155238886 (Twilio sandbox) or your business number
REACT_APP_TWILIO_WHATSAPP_NUMBER=+15550150

# ============================================================================
# SENDGRID CONFIGURATION (For Email Notifications)
# ============================================================================
# Sign up at: https://sendgrid.com
# Get API key from: Settings → API Keys

# Your SendGrid API Key
# Important: Start with "SG."
# Example: SG.xxxxxxxxxxxxxxxxxxxx
REACT_APP_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to use as sender
# This should match a verified sender in your SendGrid account
# Example: noreply@hospitalname.com
REACT_APP_FROM_EMAIL=noreply@donify.com

# ============================================================================
# OPTIONAL: Application Settings
# ============================================================================

# Application Name (for email headers)
REACT_APP_NAME=Donify

# Application URL (for email links and SMS)
REACT_APP_URL=https://donify.local

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. TWILIO SETUP:
#    a. Create account at https://www.twilio.com
#    b. Go to Console and find Account SID and Auth Token
#    c. Get a phone number (or use sandbox for testing)
#    d. Add verified numbers for SMS testing
#    e. Copy credentials to this file
#
#    For WhatsApp (optional):
#    - Use same phone number or Twilio's sandbox number
#    - Sandbox mode easier for testing

# 2. SENDGRID SETUP:
#    a. Create account at https://sendgrid.com
#    b. Verify a sender email (important!)
#    c. Go to Settings → API Keys
#    d. Create new API Key (keep it private!)
#    e. Copy API key and verified email to this file

# 3. ENABLE NOTIFICATIONS:
#    In src/services/NotificationService.js, set:
#    - this.serviceConfig.sms.enabled = true;
#    - this.serviceConfig.whatsapp.enabled = true;
#    - this.serviceConfig.email.enabled = true;

# ============================================================================
# TESTING TIPS
# ============================================================================

# Free Trial Features:
# - Twilio: $15 free credit, SMS to verified numbers
# - SendGrid: 100 emails/day free tier (no card required)

# Demo Mode (No External Services):
# - If API keys not configured, system auto-runs in demo mode
# - All notifications logged to browser console and localStorage
# - Great for development and testing

# Browser Console Access:
# F12 → Console → See "📬 Notification Log" entries
# Or check: JSON.parse(localStorage.getItem('donify_notification_logs'))

# ============================================================================
# SECURITY NOTES
# ============================================================================

# ⚠️  IMPORTANT:
# - NEVER commit this file to git!
# - Add .env to .gitignore
# - Keep API keys secret
# - Don't share .env file
# - Rotate keys regularly
# - Use environment-specific configs for production

# ============================================================================
# COMMON ISSUES & SOLUTIONS
# ============================================================================

# Issue: "Invalid API Key"
# Solution: Check your SendGrid key starts with "SG." and is complete

# Issue: "Invalid phone number"
# Solution: Use E.164 format: +[country code][area code][number]
#           Example: +1-555-0150 → +15550150

# Issue: "Authentication failed"
# Solution: Double-check Twilio Account SID and Auth Token
#           Log out and log back in to Twilio console to refresh

# Issue: "Sender not verified" (SendGrid)
# Solution: Verify sender email in SendGrid settings
#           Check confirmation email in inbox

# Issue: "Trial credit exhausted"
# Solution: Upgrade Twilio account or use sandbox mode
#           Use SendGrid free tier (100/day)

# ============================================================================
# EXAMPLE WORKING CONFIGURATION
# ============================================================================

# If using Twilio Sandbox (for testing):
# REACT_APP_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REACT_APP_TWILIO_AUTH_TOKEN=your_token_here
# REACT_APP_TWILIO_PHONE_NUMBER=+14155238886 (Twilio WhatsApp sandbox)
# REACT_APP_TWILIO_WHATSAPP_NUMBER=+14155238886

# With SendGrid Free Tier:
# REACT_APP_SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
# REACT_APP_FROM_EMAIL=your-verified-email@example.com

# ============================================================================
# SUPPORT
# ============================================================================

# For issues:
# 1. Check browser console (F12)
# 2. Verify .env variables
# 3. Review Twilio/SendGrid dashboards
# 4. Check notification logs: localStorage.getItem('donify_notification_logs')
# 5. See NOTIFICATION_SYSTEM_GUIDE.md for detailed troubleshooting

