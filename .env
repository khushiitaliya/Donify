# Donify Notification System - Environment Configuration
# Email notifications via EmailJS (FREE)

# ============================================================================
# EMAILJS CONFIGURATION (For Email Notifications - FREE)
# ============================================================================
# Sign up FREE at: https://www.emailjs.com
# 
# Setup Steps:
# 1. Go to emailjs.com → Sign up (free)
# 2. Dashboard → Email Services → Add New Service
#    - Choose Gmail or any email provider
#    - Authorize it
# 3. Dashboard → Email Templates → Create Template
#    - Use variables like {{to_email}}, {{subject}}, {{message}}
# 4. Get your IDs:
#    - Service ID: Dashboard → Email Services → Copy Service ID
#    - Template ID: Dashboard → Templates → Copy Template ID  
#    - Public Key: Dashboard → Account → API Keys → Copy Public Key

# Your EmailJS Service ID (get from emailjs.com dashboard)
# Example: service_abc123xyz
REACT_APP_EMAILJS_SERVICE_ID=service_u49geaj

# Your EmailJS Template ID (get from emailjs.com dashboard)
# Example: template_abc123xyz
REACT_APP_EMAILJS_TEMPLATE_ID=template_8cv77fo

# Your EmailJS Public Key (get from emailjs.com dashboard - Account → API Keys)
# Example: aBcDeFgHiJkLmNoPqRsT
REACT_APP_EMAILJS_PUBLIC_KEY=wHtEPn1ueZMmaYIGo

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application Name
REACT_APP_NAME=Donify

# Application URL (for email links)
REACT_APP_URL=http://localhost:3000

# MongoDB Local Connection
MONGODB_URI=mongodb://localhost:27017/donify

# ============================================================================
# IMPORTANT: SECURITY NOTES
# ============================================================================
# - NEVER commit .env to git
# - Add .env to .gitignore
# - Keep API keys secret
# - Don't share .env file
